{
    "INFO": {
        "PROJECT_NAME": "tUilKit",
        "PROJECT_FOLDER": "tUilKit",
        "PROJECT_DESCRIPTION": "Core utility toolkit for CLI apps: colour management, filesystem helpers, JSON config, dataframe utilities, logging, a command line menu interface, and testing framework.",
        "AUTHOR": "Daniel Austin <the.potato.gnome@gmail.com>",
        "VERSION": "1.1.0",
        "MAIN_ENTRY_POINT": "src/tUilKit/__init__.py"
    },

    "ROOT_MODES": {
        "ROOT_MODES: workspace" : "Paths are relative to the workspace root.",
        "ROOT_MODES: project"   : "Paths are relative to the project root.",
        "LOGS"                  : "workspace",
        "TEST_LOGS"             : "workspace",
        "CONFIG"                : "project",
        "TEST_CONFIG"           : "project"
    },
    
    "PATHS": {
        "WORKSPACE_ROOT_PATH"   : "C:/Repository/Daniel/dev_local/",
        "PROJECT_ROOT_PATH"     : "C:/Repository/Daniel/dev_local/Dev/tUilKit/",        
        "LOGS"                  : ".logs/tUilKit",
        "TEST_LOGS"             : ".test_logs/tUilKit/",
        "CONFIG"                : "config/",
        "TEST_CONFIG"           : "config/"
    },

    "SHARED_CONFIG": {
        "ENABLED"                   : true,
        "PATH"                      : "GLOBAL_SHARED.d/",
        "SHARED_CONFIG_FILES": {
            "COLOURS"               : "COLOURS.json",
            "BORDER_PATTERNS"       : "BORDER_PATTERNS.json",
            "TESTS_OPTIONS"         : "TESTS_OPTIONS.json",
            "TIME_STAMP_OPTIONS"    : "TIME_STAMP_OPTIONS.json"
        }
    },  

    "LOG_FILES": {
        "MASTER"            : "MASTER.log",
        "ERROR"             : "ERROR.log",
        "FS"                : "FS.log",
        "INIT"              : "INIT.log",
        "RUNTIME"           : "RUNTIME.log",
        "WARNING"           : "WARNING.log",
        "DATABASE"          : "DATABASE.log",
        "DEBUG"             : "DEBUG.log"
    },

    "LOG_CATEGORIES": {
        "default"           : ["MASTER", "SESSION"],
        "error"             : ["MASTER", "SESSION", "ERROR"],
        "fs"                : ["MASTER", "SESSION", "FS"],
        "init"              : ["INIT", "SESSION", "MASTER"],
        "debug"             : ["DEBUG", "SESSION"],
        "warning"           : ["WARNING", "SESSION", "MASTER"],
        "database"          : ["DATABASE", "SESSION", "MASTER"],
        "all"               : ["MASTER", "SESSION", "ERROR", "FS", "INIT", "DEBUG", "WARNING", "DATABASE"]
    }
}